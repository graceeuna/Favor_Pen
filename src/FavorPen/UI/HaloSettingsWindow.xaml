<Window x:Class="FavorPen.UI.HaloSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="마우스 하이라이트 설정"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <SolidColorBrush x:Key="Ink" Color="#FFEDEDED"/>
        <SolidColorBrush x:Key="Sub" Color="#FFB8B8B8"/>
    </Window.Resources>

    <Border CornerRadius="14" Background="#F21E1E1E" Padding="16,14"
            MouseLeftButtonDown="OnDrag">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="18" ShadowDepth="0" Opacity="0.55"/>
        </Border.Effect>

        <StackPanel Width="240">
            <TextBlock Text="마우스 하이라이트 설정"
                       Foreground="{StaticResource Ink}" FontSize="13" FontWeight="Bold"/>

            <!-- 색상 -->
            <TextBlock Text="색상" Foreground="{StaticResource Sub}" FontSize="11" Margin="0,12,0,5"/>
            <WrapPanel x:Name="Swatches"/>

            <!-- 크기(반지름) -->
            <Grid Margin="0,14,0,0">
                <TextBlock Text="크기" Foreground="{StaticResource Sub}" FontSize="11"
                           HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <TextBlock x:Name="SizeLabel" Text="28 px" Foreground="{StaticResource Ink}"
                           FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
            <Slider x:Name="SizeSlider" Minimum="8" Maximum="100" Value="28"
                    Margin="0,4,0,0" IsSnapToTickEnabled="True" TickFrequency="1"
                    ValueChanged="OnSizeChanged"/>

            <!-- 미리보기 안내 + 닫기 -->
            <Grid Margin="0,12,0,0">
                <TextBlock Text="실시간 적용됨" Foreground="{StaticResource Sub}" FontSize="10"
                           HorizontalAlignment="Left" VerticalAlignment="Center"/>
                <Button Content="닫기" Click="OnClose"
                        HorizontalAlignment="Right"
                        Foreground="{StaticResource Ink}" Background="#33FFFFFF"
                        BorderThickness="0" Padding="14,4" Cursor="Hand"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>
