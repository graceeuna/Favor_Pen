<Window x:Class="ScreenPenPortable.UI.TimerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenPen 타이머"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <SolidColorBrush x:Key="Ink" Color="#FFEDEDED"/>
        <!-- 컨트롤 버튼(작은 둥근 버튼) -->
        <Style x:Key="Ctl" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Margin" Value="3,0"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="Background" Value="#33FFFFFF"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#55FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 가운데 정렬되는 둥근 패널. 빈 영역 드래그로 이동(기본은 화면 중앙). -->
    <Border x:Name="Root" CornerRadius="18" Background="#D9101010"
            Padding="34,22" MouseLeftButtonDown="OnDrag">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="22" ShadowDepth="0" Opacity="0.6"/>
        </Border.Effect>

        <StackPanel HorizontalAlignment="Center">

            <!-- 큰 카운트다운 표시 — 임베드 폰트 메이플스토리체 Bold(pack URI). -->
            <TextBlock x:Name="TimeText" Text="05:00"
                       FontFamily="pack://application:,,,/FavorPen;component/Assets/Fonts/#Maplestory"
                       FontWeight="Bold" FontSize="140"
                       Foreground="{StaticResource Ink}"
                       HorizontalAlignment="Center" TextAlignment="Center"/>

            <!-- 시간 설정 + 글자 크기 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
                <Button Style="{StaticResource Ctl}" Content="−1분" ToolTip="1분 감소" Click="OnMinusMin"/>
                <Button Style="{StaticResource Ctl}" Content="+1분" ToolTip="1분 증가" Click="OnPlusMin"/>
                <Button Style="{StaticResource Ctl}" Content="−10초" ToolTip="10초 감소" Click="OnMinusSec"/>
                <Button Style="{StaticResource Ctl}" Content="+10초" ToolTip="10초 증가" Click="OnPlusSec"/>
                <Border Width="14"/>
                <Button Style="{StaticResource Ctl}" Content="A−" ToolTip="글자 작게" Click="OnSmaller"/>
                <Button Style="{StaticResource Ctl}" Content="A+" ToolTip="글자 크게" Click="OnLarger"/>
            </StackPanel>

            <!-- 실행 컨트롤 -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                <Button x:Name="StartButton" Style="{StaticResource Ctl}" Content="▶ 시작" Click="OnStartPause"/>
                <Button Style="{StaticResource Ctl}" Content="↺ 리셋" Click="OnReset"/>
                <Button Style="{StaticResource Ctl}" Content="✕ 닫기" Click="OnCloseClick"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
