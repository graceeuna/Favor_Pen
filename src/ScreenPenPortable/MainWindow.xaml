<Window x:Class="ScreenPenPortable.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ScreenPenPortable"
        mc:Ignorable="d"
        Title="FavorPen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual"
        KeyDown="OnKeyDown">
    <Grid>
        <!-- ① 백드롭 레이어(잉크 뒤): FR-16 화이트보드/블랙보드 불투명 배경.
             기본 Collapsed. WhiteboardController 가 색/표시 영역을 제어한다. -->
        <Border x:Name="BackdropLayer" Visibility="Collapsed"/>

        <!-- ② 그리기 표면(InkCanvas): 펜/하이라이터/지우개 스트로크 + 커밋된 벡터 객체
             (도형·텍스트·넘버링)는 InkSurface.Children 으로 추가된다.
             ★ 배경 alpha는 0이면 안 된다: 완전 투명(alpha=0) 픽셀 위에서는 OS가 레이어드 창을
             건너뛰어(Raw Input Thread skip) 마우스 입력이 아래 앱으로 통과 → 그림이 안 그려진다.
             #01000000(alpha 1/255, 사실상 비가시)로 두면 입력을 포착하면서도 화면엔 안 보인다.
             통과 모드에서는 WS_EX_TRANSPARENT로 강제 통과하므로 영향 없음. -->
        <InkCanvas x:Name="InkSurface" Background="#01000000"/>

        <!-- ③ 오버레이 레이어(잉크 위, 입력 비차단): 도형 드래그 미리보기 + FR-21 헤일로 커서.
             IsHitTestVisible=False 이므로 마우스 입력을 가로채지 않는다(시각 전용). -->
        <Canvas x:Name="OverlayLayer" IsHitTestVisible="False"/>
    </Grid>
</Window>
