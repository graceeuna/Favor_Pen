<Window x:Class="ScreenPenPortable.UI.ToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ScreenPenPortable.UI"
        mc:Ignorable="d"
        Title="ScreenPen 툴바"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <!-- ── 색상 팔레트 ──────────────────────────────────────── -->
        <SolidColorBrush x:Key="BarBackground" Color="#F21E1E1E"/>
        <SolidColorBrush x:Key="BtnIdle" Color="Transparent"/>
        <SolidColorBrush x:Key="BtnHover" Color="#33FFFFFF"/>
        <SolidColorBrush x:Key="BtnActive" Color="#FF3D7DFF"/>
        <SolidColorBrush x:Key="Ink" Color="#FFEDEDED"/>
        <SolidColorBrush x:Key="Divider" Color="#33FFFFFF"/>

        <!-- ── 공통 도구 버튼 스타일(아이콘 글리프) ──────────────── -->
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="1,1"/>
            <Setter Property="Foreground" Value="{StaticResource Ink}"/>
            <Setter Property="Background" Value="{StaticResource BtnIdle}"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                CornerRadius="6"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{StaticResource BtnHover}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 가로 구분선(세로 레이아웃용) -->
        <Style x:Key="HSep" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Width" Value="68"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Background" Value="{StaticResource Divider}"/>
        </Style>
    </Window.Resources>

    <!-- 바깥 Border 가 실제 배경(둥근 모서리). 세로 2열 도구박스. -->
    <Border CornerRadius="12"
            Background="{StaticResource BarBackground}"
            Padding="8,6"
            MouseLeftButtonDown="OnDragArea_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="14"
                              ShadowDepth="0" Opacity="0.5"/>
        </Border.Effect>

        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">

            <!-- ── 드래그 핸들(상단 가로 바): 잡고 드래그하면 툴바 이동 ── -->
            <Border x:Name="DragHandle"
                    Width="68" Height="18"
                    Background="#2EFFFFFF"
                    CornerRadius="5"
                    Margin="0,0,0,2"
                    Cursor="SizeAll"
                    ToolTip="여기를 잡고 드래그하여 툴바 이동 (모니터 간 이동 가능)"
                    MouseLeftButtonDown="OnDragArea_MouseLeftButtonDown">
                <TextBlock Text="&#x28FF;&#x28FF;" Foreground="{StaticResource Ink}"
                           FontSize="13" Opacity="0.85"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <Border Style="{StaticResource HSep}"/>

            <!-- ── 도구(2열): 펜·하이라이터·지우개 / 도형 4종·채움 / 텍스트·넘버 ── -->
            <WrapPanel Width="72" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="PenButton" Style="{StaticResource ToolButton}"
                        Content="&#x270E;" ToolTip="펜 (Ctrl+Alt+1)" Click="OnPenClick"/>
                <Button x:Name="HighlighterButton" Style="{StaticResource ToolButton}"
                        Content="&#x1F58D;" ToolTip="하이라이터 (Ctrl+Alt+2)" Click="OnHighlighterClick"/>
                <Button x:Name="EraserButton" Style="{StaticResource ToolButton}"
                        Content="&#x232B;" ToolTip="지우개 (Ctrl+Alt+3)" Click="OnEraserClick"/>
                <Button x:Name="LineButton" Style="{StaticResource ToolButton}"
                        Content="&#x2571;" ToolTip="직선 (Shift=각도 스냅)" Click="OnLineClick"/>
                <Button x:Name="ArrowButton" Style="{StaticResource ToolButton}"
                        Content="&#x2197;" ToolTip="화살표" Click="OnArrowClick"/>
                <Button x:Name="RectButton" Style="{StaticResource ToolButton}"
                        Content="&#x25AD;" ToolTip="사각형 (Shift=정사각형)" Click="OnRectClick"/>
                <Button x:Name="EllipseButton" Style="{StaticResource ToolButton}"
                        Content="&#x25EF;" ToolTip="타원 (Shift=정원)" Click="OnEllipseClick"/>
                <Button x:Name="FillButton" Style="{StaticResource ToolButton}"
                        Content="&#x25D1;" ToolTip="도형 채움 순환: 없음→컬러→외곽선→흰색→검정" Click="OnFillClick"/>
                <Button x:Name="TextButton" Style="{StaticResource ToolButton}"
                        Content="T" FontWeight="Bold" ToolTip="텍스트" Click="OnTextClick"/>
                <Button x:Name="NumberButton" Style="{StaticResource ToolButton}"
                        Content="&#x2460;" ToolTip="넘버링 태그 (클릭마다 1,2,3…)" Click="OnNumberClick"/>
            </WrapPanel>

            <Border Style="{StaticResource HSep}"/>

            <!-- ── Quick 색상 스와치(2열로 wrap; SetQuickColors 로 채워짐) ── -->
            <ItemsControl x:Name="ColorSwatches" Width="72" HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>

            <Border Style="{StaticResource HSep}"/>

            <!-- ── 굵기 슬라이더(1~40) + 값 ─────────────────────── -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Slider x:Name="ThicknessSlider"
                        Width="46" Minimum="1" Maximum="40" Value="3"
                        VerticalAlignment="Center"
                        IsSnapToTickEnabled="False"
                        ToolTip="굵기"
                        ValueChanged="OnThicknessChanged"/>
                <TextBlock x:Name="ThicknessLabel" Text="3"
                           Foreground="{StaticResource Ink}" FontSize="11"
                           Width="20" TextAlignment="Center"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <Border Style="{StaticResource HSep}"/>

            <!-- ── 편집(2열): Undo / Redo / 전체지우기 ───────────── -->
            <WrapPanel Width="72" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="UndoButton" Style="{StaticResource ToolButton}"
                        Content="&#x21A9;" ToolTip="실행 취소 (Ctrl+Alt+Z)" Click="OnUndoClick"/>
                <Button x:Name="RedoButton" Style="{StaticResource ToolButton}"
                        Content="&#x21AA;" ToolTip="다시 실행 (Ctrl+Alt+Y)" Click="OnRedoClick"/>
                <Button x:Name="ClearButton" Style="{StaticResource ToolButton}"
                        Content="&#x1F5D1;" ToolTip="전체 지우기 (Ctrl+Alt+E)" Click="OnClearClick"/>
            </WrapPanel>

            <Border Style="{StaticResource HSep}"/>

            <!-- ── 캡처 / 모드(2열) ─────────────────────────────── -->
            <WrapPanel Width="72" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="ScreenshotButton" Style="{StaticResource ToolButton}"
                        Content="&#x1F4F7;" ToolTip="스크린샷 (Ctrl+Alt+S)" Click="OnScreenshotClick"/>
                <Button x:Name="PassThroughButton" Style="{StaticResource ToolButton}"
                        Content="&#x270B;" ToolTip="그리기 / 통과 모드 전환 (Ctrl+Alt+D)" Click="OnPassThroughClick"/>
            </WrapPanel>

            <Border Style="{StaticResource HSep}"/>

            <!-- ── 보드 / 효과(2열): 화이트보드·고스트·돋보기·페이드·헤일로 ── -->
            <WrapPanel Width="72" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="WhiteboardButton" Style="{StaticResource ToolButton}"
                        Content="&#x2B1C;" ToolTip="화이트보드/블랙보드 순환 (Ctrl+Alt+W)" Click="OnWhiteboardClick"/>
                <Button x:Name="GhostButton" Style="{StaticResource ToolButton}"
                        Content="&#x1F47B;" ToolTip="고스트 모드: 툴바 숨김·핫키만 (Ctrl+Alt+G)" Click="OnGhostClick"/>
                <Button x:Name="MagnifierButton" Style="{StaticResource ToolButton}"
                        Content="&#x1F50D;" ToolTip="돋보기 (Ctrl+Alt+M)" Click="OnMagnifierClick"/>
                <Button x:Name="FadeButton" Style="{StaticResource ToolButton}"
                        Content="&#x1F32B;" ToolTip="페이딩 잉크: 그린 뒤 자동 사라짐 (Ctrl+Alt+F)" Click="OnFadeClick"/>
                <Button x:Name="HaloButton" Style="{StaticResource ToolButton}"
                        Content="&#x25CE;" ToolTip="하이라이트 커서(헤일로) (Ctrl+Alt+H)" Click="OnHaloClick"/>
            </WrapPanel>

            <Border Style="{StaticResource HSep}"/>

            <!-- ── 종료 ─────────────────────────────────────────── -->
            <Button x:Name="ExitButton" Style="{StaticResource ToolButton}"
                    Content="&#x2715;" ToolTip="종료 (Ctrl+Alt+Q)"
                    Foreground="#FFFF6B6B" Click="OnExitClick"/>
        </StackPanel>
    </Border>
</Window>
